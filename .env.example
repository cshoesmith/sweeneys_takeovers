# Untappd access token (run: python fetch_checkins.py --login)
# Uses the same OAuth proxy as the Friendmap app
UNTAPPD_ACCESS_TOKEN=

# Hotel Sweeneys venue ID on Untappd
# If you don't know it, run: python fetch_checkins.py --search "Hotel Sweeneys"
VENUE_ID=26498

# Optional but recommended: set the Untappd username allowed to see the extra
# Takeovers/Admin tab buttons. If left blank, no login gets those tabs and the
# deployed site shows a reminder popup telling users the real admin still needs
# to configure PRIVILEGED_TAB_USERNAME.
PRIVILEGED_TAB_USERNAME=
